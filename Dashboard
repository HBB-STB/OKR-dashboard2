<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --cream:#fbf7f2;--rust:#b23520;--forest:#1d2813;--coal:#111;
  --s1:#c0392b;--s2:#e07020;--s3:#b8880a;--s4:#27ae60;--s5:#1a4d1a;
  --border:#e0d8ce;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--cream);color:var(--coal);height:100vh;display:flex;flex-direction:column;font-size:13px;overflow:hidden}

/* HEADER */
.hdr{background:var(--forest);color:var(--cream);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:46px;flex-shrink:0}
.hdr-left{display:flex;align-items:center;gap:14px}
.hdr-brand{font-size:10px;letter-spacing:2px;opacity:.5;text-transform:uppercase}
.hdr-sep{width:1px;height:16px;background:rgba(255,255,255,.2)}
.hdr-title{font-size:14px;font-weight:600}
.hdr-right{font-size:11px;opacity:.45}

/* TABS */
.tabs{background:var(--forest);display:flex;padding:0 16px;flex-shrink:0;border-bottom:2px solid rgba(0,0,0,.2);overflow-x:auto}
.tabs::-webkit-scrollbar{display:none}
.tab{padding:9px 16px;font-size:12px;color:rgba(255,255,255,.45);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:all .15s}
.tab:hover{color:rgba(255,255,255,.75)}
.tab.active{color:var(--cream);border-bottom-color:var(--cream);font-weight:500}

/* PAGES */
.page{display:none;flex:1;overflow:hidden;flex-direction:column}
.page.active{display:flex}

/* ===== FORSIDE ===== */
.forside{flex:1;overflow-y:auto;padding:24px 24px 40px}
.fs-title{font-size:18px;font-weight:700;margin-bottom:4px}
.fs-sub{font-size:12px;color:#888;margin-bottom:20px}
.fs-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:24px}
.fs-stat{background:#fff;border:1px solid var(--border);border-radius:6px;padding:14px 16px}
.fs-stat .v{font-size:24px;font-weight:700;line-height:1}
.fs-stat .l{font-size:10px;color:#999;text-transform:uppercase;letter-spacing:.5px;margin-top:3px}
.fs-stat.crit .v{color:var(--s1)}
.fs-stat.good .v{color:var(--s4)}
.hotel-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.hcard{background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;cursor:pointer;transition:box-shadow .15s}
.hcard:hover{box-shadow:0 3px 14px rgba(0,0,0,.12)}
.hcard-top{background:var(--forest);color:var(--cream);padding:11px 14px}
.hcard-code{font-size:9px;letter-spacing:1.5px;opacity:.55;text-transform:uppercase}
.hcard-name{font-size:13px;font-weight:600;margin-top:2px;line-height:1.2}
.hcard-body{padding:12px 14px}
.hcard-stats{display:flex;justify-content:space-between;margin-bottom:9px}
.hcs .v{font-size:17px;font-weight:700;text-align:center}
.hcs .l{font-size:9px;color:#aaa;text-transform:uppercase;letter-spacing:.4px;text-align:center}
.bar-lbl{font-size:9px;color:#bbb;margin-bottom:3px}
.bar{display:flex;height:7px;border-radius:3px;overflow:hidden;gap:1px}
.bseg{height:100%}
.issues{margin-top:8px;padding:6px 8px;background:#fdf5f4;border-radius:4px;border-left:3px solid var(--rust)}
.issues p{font-size:10.5px;color:var(--rust);line-height:1.4}
.issues .it{font-weight:600;margin-bottom:1px}
.go-btn{margin-top:9px;width:100%;padding:5px;border:1px solid var(--border);background:var(--cream);border-radius:4px;font-size:10.5px;cursor:pointer;color:#666}
.go-btn:hover{background:var(--forest);color:#fff;border-color:var(--forest)}

/* ===== HOTEL PAGE ===== */
.hotel-page{flex:1;display:flex;flex-direction:column;overflow:hidden}

/* mini stats */
.mini-stats{background:#fff;border-bottom:1px solid var(--border);display:flex;gap:1px;flex-shrink:0}
.mstat{flex:1;padding:8px 14px;border-right:1px solid var(--border)}
.mstat:last-child{border-right:none}
.mstat .v{font-size:18px;font-weight:700;line-height:1}
.mstat .l{font-size:9px;color:#aaa;text-transform:uppercase;letter-spacing:.4px;margin-top:2px}
.mstat.crit .v{color:var(--s1)}
.mstat.good .v{color:var(--s4)}

/* filters */
.filters{background:#fff;border-bottom:1px solid var(--border);padding:6px 14px;display:flex;gap:7px;flex-wrap:wrap;align-items:center;flex-shrink:0}
.fg{display:flex;gap:3px;align-items:center}
.fgl{font-size:9.5px;color:#bbb;text-transform:uppercase;letter-spacing:.5px;margin-right:2px;white-space:nowrap}
.chip{padding:2px 8px;border-radius:20px;border:1px solid var(--border);background:#fff;font-size:11px;cursor:pointer;transition:all .1s;color:#666;white-space:nowrap}
.chip:hover{border-color:#aaa}
.chip.active{background:var(--forest);color:#fff;border-color:var(--forest)}
.search-w{margin-left:auto}
.search-w input{padding:3px 9px;border:1px solid var(--border);border-radius:4px;font-size:11.5px;width:170px;background:var(--cream);outline:none}
.search-w input:focus{border-color:#aaa}

/* main split */
.main{display:flex;flex:1;overflow:hidden}

/* list */
.list-pane{flex:1;overflow-y:auto;background:var(--cream)}
.list-topbar{background:#fff;padding:5px 14px;font-size:10.5px;color:#aaa;border-bottom:1px solid var(--border);display:flex;align-items:center;position:sticky;top:0;z-index:6}
.list-topbar .cnt{margin-left:auto;font-weight:600;color:var(--coal)}
.ghdr{background:#ede6dc;padding:4px 14px;border-bottom:1px solid var(--border);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#777;position:sticky;top:27px;z-index:5;display:flex;align-items:center;gap:6px}
.ghdr-cnt{font-size:9.5px;color:#aaa;background:rgba(0,0,0,.08);padding:1px 6px;border-radius:10px}
.row{display:flex;align-items:center;gap:7px;padding:7px 14px;border-bottom:1px solid var(--border);background:#fff;cursor:pointer;transition:background .08s}
.row:hover{background:#f6f1ea}
.row.sel{background:#e8f5ec;border-left:3px solid var(--s4)}
.tbadge{flex-shrink:0;font-size:9.5px;font-weight:700;padding:2px 5px;border-radius:3px;text-transform:uppercase;letter-spacing:.4px;min-width:26px;text-align:center}
.tbadge.KR{background:#fde8e8;color:var(--rust)}
.tbadge.I{background:#e8f0ff;color:#2255cc}
.tbadge.O{background:#fff3cd;color:#7d5a00}
.row-text{flex:1;font-size:12px;line-height:1.35;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.row-meta{display:flex;align-items:center;gap:4px;flex-shrink:0}
.tag{font-size:9.5px;padding:2px 5px;border-radius:3px;white-space:nowrap}
.tag.own{background:#faf0f5;color:#8b2252;max-width:90px;overflow:hidden;text-overflow:ellipsis}
.tag.bp{background:#f0f0f0;color:#aaa}
.tag.br{background:#fff3e0;color:#b45000}
.tag.bf{background:#e8f0ff;color:#1a44aa}
.tag.ba{background:#e8f4ec;color:#1a6b30}
.sc{flex-shrink:0;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10.5px;font-weight:700;color:#fff}
.sc1{background:var(--s1)}.sc2{background:var(--s2)}.sc3{background:var(--s3)}.sc4{background:var(--s4)}.sc5{background:var(--s5)}
.empty{text-align:center;padding:50px;color:#ccc;font-size:12px}

/* detail */
.detail-pane{width:370px;border-left:1px solid var(--border);background:#fff;display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
.d-empty{flex:1;display:flex;align-items:center;justify-content:center;color:#ccc;padding:20px;text-align:center;font-size:12px}
.d-hdr{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;gap:7px;align-items:flex-start}
