const BPM_ALL = ['Ikke påbegynt','Vurdert av HQ','Feedback sendt','Godkjent'];
const SL = {1:'Svak',2:'Under standard',3:'Akseptabel',4:'God',5:'Sterk'};
const OSL = {1:'Mangler inspirasjon',2:'Inneholder metric',3:'Vag retning',4:'God retning',5:'Inspirerende'};
const DORDER = ['LG','F&B','Reception','Housekeeping','Sales','Other'];
const HNAMES = {'NO127':'The Thief','NO136':'Christiania Teater','NO147':'Amerikalinjen','NO154':'Sommerro','NO175':'Hobo Oslo'};
const SC_COLORS = ['#c0392b','#e07020','#b8880a','#27ae60','#1a4d1a'];

// Per-hotel filter state
const FS = {};
['NO127','NO136','NO147','NO154','NO175'].forEach(c => {
  FS[c] = {type:'ALL', dept:'ALL', score:'ALL', bpm:'ALL', search:''};
});
const SEL = {}; // selected row id per hotel

function gst(id){try{return JSON.parse(localStorage.getItem('nhr4_'+id)||'null')}catch{return null}}
function sst(id,bpm,note){localStorage.setItem('nhr4_'+id,JSON.stringify({bpm,note}))}
function gbpm(id){const s=gst(id);return s?s.bpm:'Ikke påbegynt'}
function gnote(id){const s=gst(id);return s?s.note||'':''}
function btagcls(bpm){
  if(bpm==='Vurdert av HQ')return'br';
  if(bpm==='Feedback sendt')return'bf';
  if(bpm==='Godkjent')return'ba';
  return'bp';
}
function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

function getFiltered(code) {
  const f = FS[code];
  return RAW.filter(d => {
    if(d.hotelCode !== code) return false;
    if(f.type !== 'ALL' && d.type !== f.type) return false;
    if(f.dept !== 'ALL' && d.dept !== f.dept) return false;
    if(f.score === 'LOW' && d.score > 2) return false;
    if(f.score === 'MID' && d.score !== 3) return false;
    if(f.score === 'HIGH' && d.score < 4) return false;
    if(f.bpm !== 'ALL' && gbpm(d.id) !== f.bpm) return false;
    if(f.search) {
      const q = f.search.toLowerCase();
      if(!((d.text||'')+(d.owner||'')+(d.cat||'')+(d.dept||'')+(d.objective||'')).toLowerCase().includes(q)) return false;
    }
    return true;
  });
}

function renderMiniStats(code) {
  const rows = RAW.filter(d => d.hotelCode === code);
  const n = rows.length;
  const avg = n ? (rows.reduce((s,d)=>s+d.score,0)/n).toFixed(1) : '-';
  const crit = rows.filter(d=>d.score<=2).length;
  const appr = rows.filter(d=>gbpm(d.id)==='Godkjent').length;
  document.getElementById('ms-'+code.toLowerCase()).innerHTML = `
    <div class="mstat"><div class="v">${n}</div><div class="l">Rader</div></div>
    <div class="mstat"><div class="v">${avg}</div><div class="l">Snitt score</div></div>
    <div class="mstat crit"><div class="v">${crit}</div><div class="l">Kritiske (1–2)</div></div>
    <div class="mstat good"><div class="v">${appr}</div><div class="l">Godkjente</div></div>
  `;
}

function renderList(code) {
  const cid = code.toLowerCase();
  const rows = getFiltered(code);
  document.getElementById('cnt-'+cid).textContent = '· '+rows.length;

  const body = document.getElementById('body-'+cid);
  if(!rows.length){body.innerHTML='<div class="empty">Ingen rader matcher filtrene</div>';return;}

  // Group by dept
  const groups = {};
  rows.forEach(d => {
    const k = d.dept || 'Other';
    if(!groups[k]) groups[k] = [];
    groups[k].push(d);
  });
  const sorted = Object.entries(groups).sort((a,b) => DORDER.indexOf(a[0]) - DORDER.indexOf(b[0]));

  let html = '';
  sorted.forEach(([dept, drows]) => {
    html += `<div class="ghdr">${dept}<span class="ghdr-cnt">${drows.length}</span></div>`;
    drows.forEach(d => {
      const bpm = gbpm(d.id);
      const bc = btagcls(bpm);
      const bs = bpm !== 'Ikke påbegynt' ? bpm : '–';
      const own = d.owner ? d.owner.substring(0,20) : '';
      const label = d.type === 'O' ? 'OBJ' : d.type;
      html += `<div class="row${d.id===SEL[code]?' sel':''}" data-id="${d.id}" data-code="${code}">
        <span class="tbadge ${d.type}">${label}</span>
        <span class="row-text">${esc(d.text)}</span>
        <div class="row-meta">
          <span class="tag ${bc}">${bs}</span>
          ${own ? `<span class="tag own">${esc(own)}</span>` : ''}
          <div class="sc sc${d.score}">${d.score}</div>
        </div>
      </div>`;
    });
  });
  body.innerHTML = html;
}

function renderDetail(code, id) {
  const d = RAW.find(r => r.id === id);
  const pane = document.getElementById('detail-'+code.toLowerCase());
  if(!d){pane.innerHTML='<div class="d-empty">Velg en rad for å se detaljer</div>';return;}
  const bpm = gbpm(id), note = gnote(id);
  const label = d.type === 'O' ? 'OBJ' : d.type;
  const scoreLabel = d.type === 'O' ? (OSL[d.score]||SL[d.score]) : SL[d.score];

  const objH = d.objective ? `<div><div class="slbl">Overordnet Objective</div><div class="obj-box">${esc(d.objective)}</div></div>` : '';
  const aiH = (d.critique||d.rewrite) ? `<div><div class="slbl">AI-analyse</div><div class="ai-box">
    <div class="ai-hdr">HQ-assistent</div>
    ${d.critique ? `<div class="ai-crit">${esc(d.critique)}</div>` : ''}
    ${d.rewrite ? `<div class="ai-rw-lbl">Foreslått omskrivning</div><div class="ai-rw">"${esc(d.rewrite)}"</div>` : ''}
  </div></div>` : '';
  const tgt = d.targetValue ? `<div><div class="mk">Mål</div><div class="mv">${esc(d.targetValue)}</div></div>` : '';
  const cur = d.currentValue ? `<div><div class="mk">Nåværende</div><div class="mv">${esc(d.currentValue)}</div></div>` : '';

  pane.innerHTML = `
    <div class="d-hdr"><span class="tbadge ${d.type}">${label}</span><div class="d-title">${esc(d.text)}</div></div>
    <div class="d-body">
      <div><div class="slbl">Score</div><span class="sbadge sc${d.score}">${d.score} — ${scoreLabel}</span></div>
      ${objH}
      <div><div class="slbl">Metadata</div><div class="mgrid">
        <div><div class="mk">Kategori</div><div class="mv${d.cat?'':' empty'}">${esc(d.cat)||'–'}</div></div>
        <div><div class="mk">Avdeling</div><div class="mv${d.dept?'':' empty'}">${esc(d.dept)||'–'}</div></div>
        <div><div class="mk">Eier</div><div class="mv${d.owner?'':' empty'}">${esc(d.owner)||'–'}</div></div>
        <div><div class="mk">Startdato</div><div class="mv${d.startDate?'':' empty'}">${esc(d.startDate)||'–'}</div></div>
        <div><div class="mk">Sluttdato</div><div class="mv${d.dueDate?'':' empty'}">${esc(d.dueDate)||'–'}</div></div>
        ${tgt}${cur}
        ${d.linkedKR ? `<div style="grid-column:1/-1"><div class="mk">Koblet KR</div><div class="mv" style="font-size:11px">${esc(d.linkedKR)}</div></div>` : ''}
      </div></div>
      ${aiH}
      <div><div class="slbl">BPM-status</div>
        <select class="bpm-sel" id="bsel-${id.replace(/[^a-zA-Z0-9]/g,'_')}">
          ${BPM_ALL.map(s=>`<option value="${s}"${bpm===s?' selected':''}>${s}</option>`).join('')}
        </select>
      </div>
      <div><div class="slbl">HQ-notat</div>
        <textarea class="notes" id="nfld-${id.replace(/[^a-zA-Z0-9]/g,'_')}" placeholder="Skriv HQ-kommentar...">${esc(note)}</textarea>
      </div>
      <div class="arow">
        <button class="sbtn" id="sbtn-${id.replace(/[^a-zA-Z0-9]/g,'_')}" onclick="saveD('${id}','${code}')">Lagre</button>
        <span id="smsg-${id.replace(/[^a-zA-Z0-9]/g,'_')}" class="smsg"></span>
      </div>
    </div>`;
}

function saveD(id, code) {
  const sid = id.replace(/[^a-zA-Z0-9]/g,'_');
  const bpm = document.getElementById('bsel-'+sid).value;
  const note = document.getElementById('nfld-'+sid).value;
  sst(id, bpm, note);
  const btn = document.getElementById('sbtn-'+sid);
  const msg = document.getElementById('smsg-'+sid);
  btn.textContent='Lagret ✓'; btn.classList.add('saved');
  msg.textContent = new Date().toLocaleTimeString('nb-NO');
  setTimeout(()=>{btn.textContent='Lagre';btn.classList.remove('saved')},2000);
  renderList(code);
  renderMiniStats(code);
}

function renderHotel(code) {
  renderMiniStats(code);
  renderList(code);
  const selId = SEL[code];
  if(selId) renderDetail(code, selId);
}

// FORSIDE
function renderForside() {
  const total = RAW.length;
  const avg = (RAW.reduce((s,d)=>s+d.score,0)/total).toFixed(1);
  const crit = RAW.filter(d=>d.score<=2).length;
  const appr = RAW.filter(d=>gbpm(d.id)==='Godkjent').length;
  document.getElementById('fs-total').textContent=total;
  document.getElementById('fs-avg').textContent=avg;
  document.getElementById('fs-crit').textContent=crit;
  document.getElementById('fs-appr').textContent=appr;

  const codes = ['NO127','NO136','NO147','NO154','NO175'];
  document.getElementById('hotelCards').innerHTML = codes.map(code => {
    const rows = RAW.filter(d=>d.hotelCode===code);
    const n = rows.length;
    const av = (rows.reduce((s,d)=>s+d.score,0)/n).toFixed(1);
    const acol = parseFloat(av)<3?'#c0392b':parseFloat(av)>=4?'#27ae60':'#b8880a';
    const segs = [1,2,3,4,5].map(i=>{
      const v=rows.filter(d=>d.score===i).length;
      return v?`<div class="bseg" style="width:${(v/n*100).toFixed(1)}%;background:${SC_COLORS[i-1]}" title="${v} rader score ${i}"></div>`:'';
    }).join('');
    const noOwner=rows.filter(d=>!d.owner||!d.owner.trim()).length;
    const noDates=rows.filter(d=>d.type==='I'&&(!d.startDate||!d.dueDate)).length;
    const critical=rows.filter(d=>d.score<=2).length;
    const issues=[];
    if(noOwner)issues.push(noOwner+' rader uten eier');
    if(noDates)issues.push(noDates+' initiativ mangler datoer');
    if(critical)issues.push(critical+' kritiske score');
    const issHtml=issues.length?`<div class="issues"><p class="it">Viktigste avvik</p><p>${issues.join(' · ')}</p></div>`:'';
    return `<div class="hcard">
      <div class="hcard-top"><div class="hcard-code">${code}</div><div class="hcard-name">${HNAMES[code]}</div></div>
      <div class="hcard-body">
        <div class="hcard-stats">
          <div class="hcs"><div class="v">${n}</div><div class="l">Rader</div></div>
          <div class="hcs"><div class="v" style="color:${acol}">${av}</div><div class="l">Snitt</div></div>
          <div class="hcs"><div class="v">${rows.filter(d=>d.type==='KR').length}</div><div class="l">KR</div></div>
          <div class="hcs"><div class="v">${rows.filter(d=>d.type==='I').length}</div><div class="l">Init.</div></div>
        </div>
        <div class="bar-lbl">Score-fordeling</div>
        <div class="bar">${segs}</div>
        ${issHtml}
        <button class="go-btn" onclick="goToHotel('${code}')">Gå til ${HNAMES[code]} →</button>
      </div>
    </div>`;
  }).join('');
}

function goToHotel(code) {
  switchPage(code.toLowerCase());
}

function switchPage(page) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelector(`.tab[data-page="${page}"]`).classList.add('active');
  document.getElementById('page-'+page).classList.add('active');
  if(page !== 'forside') renderHotel(page.toUpperCase().replace('NO','NO'));
}

// EVENT: tab clicks
document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => {
  const page = t.dataset.page;
  switchPage(page);
  if(page !== 'forside') {
    const code = page.toUpperCase();
    renderHotel(code);
  }
}));

// EVENT: list row click
document.addEventListener('click', e => {
  const row = e.target.closest('.row[data-id]');
  if(!row) return;
  const id = row.dataset.id;
  const code = row.dataset.code;
  SEL[code] = id;
  renderList(code);
  renderDetail(code, id);
});

// EVENT: filter chips
document.querySelectorAll('.chip[data-type]').forEach(b => b.addEventListener('click', () => {
  const code = b.dataset.hotel;
  document.querySelectorAll(`.chip[data-hotel="${code}"][data-type]`).forEach(x=>x.classList.remove('active'));
  b.classList.add('active');
  FS[code].type = b.dataset.type;
  renderList(code);
}));
document.querySelectorAll('.chip[data-dept]').forEach(b => b.addEventListener('click', () => {
  const code = b.dataset.hotel;
  document.querySelectorAll(`.chip[data-hotel="${code}"][data-dept]`).forEach(x=>x.classList.remove('active'));
  b.classList.add('active');
  FS[code].dept = b.dataset.dept;
  renderList(code);
}));
document.querySelectorAll('.chip[data-score]').forEach(b => b.addEventListener('click', () => {
  const code = b.dataset.hotel;
  document.querySelectorAll(`.chip[data-hotel="${code}"][data-score]`).forEach(x=>x.classList.remove('active'));
  b.classList.add('active');
  FS[code].score = b.dataset.score;
  renderList(code);
}));
document.querySelectorAll('.chip[data-bpm]').forEach(b => b.addEventListener('click', () => {
  const code = b.dataset.hotel;
  document.querySelectorAll(`.chip[data-hotel="${code}"][data-bpm]`).forEach(x=>x.classList.remove('active'));
  b.classList.add('active');
  FS[code].bpm = b.dataset.bpm;
  renderList(code);
}));

function onSearch(code, val) {
  FS[code].search = val.trim();
  renderList(code);
}

// INIT
renderForside();
</script>
</body>
</html>
